{
  "manifest_version": 3,
  "name": "Ghost Check for Instagram",
  "version": "1.0.0",
  "description": "See who you follow on Instagram that doesn't follow you back. Runs entirely in your browser using your own session.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.instagram.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ghost Check"
  }
}
